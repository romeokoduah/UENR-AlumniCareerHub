// Postgres schema. Used with Neon in production; run against any Postgres
// (including Neon's free branching for local dev).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // native = local dev OS; rhel-openssl-3.0.x = Vercel serverless Node 20
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  STUDENT
  ALUMNI
  EMPLOYER
  ADMIN
}

enum OpportunityType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  NATIONAL_SERVICE
  VOLUNTEER
  CONTRACT
}

enum LocationType {
  REMOTE
  ONSITE
  HYBRID
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum ScholarshipSource {
  USER
  ADMIN
  INGESTED
}

enum ScholarshipStatus {
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  EXPIRED
}

enum OpportunitySource {
  USER
  ADMIN
  INGESTED
}

enum OpportunityStatus {
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  EXPIRED
}

enum ScholarshipLevel {
  UNDERGRAD
  MASTERS
  PHD
  POSTDOC
  OTHER
}

enum MatchStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  OPPORTUNITY_MATCH
  MENTORSHIP_REQUEST
  SESSION_REMINDER
  APPLICATION_UPDATE
  EVENT_REMINDER
  ANNOUNCEMENT
  MESSAGE
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  passwordHash           String
  role                   Role      @default(STUDENT)
  firstName              String
  lastName               String
  avatar                 String?
  bio                    String?
  programme              String?
  graduationYear         Int?
  studentId              String?
  skills                 String[]  @default([])
  linkedinUrl            String?
  phone                  String?
  location               String?
  currentRole            String?
  currentCompany         String?
  isVerified             Boolean   @default(false)
  isApproved             Boolean   @default(false)
  isSuperuser            Boolean   @default(false)
  profileComplete        Boolean   @default(false)
  visibility             String    @default("members")
  suspendedAt            DateTime?
  deletedAt              DateTime?
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?
  tokenVersion           Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  opportunitiesPosted Opportunity[]           @relation("PostedOpportunities")
  applications        Application[]
  bookmarks           Bookmark[]
  scholarshipsPosted  Scholarship[]           @relation("PostedScholarships")
  mentorProfile       MentorProfile?
  mentorMatches       MentorshipMatch[]       @relation("Mentor")
  menteeMatches       MentorshipMatch[]       @relation("Mentee")
  eventsHosted        Event[]                 @relation("HostedEvents")
  eventRegistrations  EventRegistration[]
  notifications       Notification[]
  cvs                 CV[]
  interviewPosts      InterviewExperience[]
  chatMessages        ChatMessage[]
  messagesSent        Message[]               @relation("MessagesSent")
  messagesReceived    Message[]               @relation("MessagesReceived")
  careerActivity      CareerToolsActivity[]
  coverLetters        CoverLetter[]
  portfolios          Portfolio[]
  vaultDocuments      VaultDocument[]
  skillAssessments    SkillAssessment[]
  learningProgress    LearningProgress[]
  certifications      Certification[]
  resourcesSubmitted  LearningResource[]      @relation("SubmittedResources")
  questionVotes       InterviewQuestionVote[]
  aptitudeAttempts    AptitudeAttempt[]
  gigsPosted          FreelanceGig[]          @relation("PostedGigs")
  gigBids             FreelanceBid[]          @relation("Bids")
  reviewsGiven        FreelanceReview[]       @relation("GivenReviews")
  reviewsReceived     FreelanceReview[]       @relation("ReceivedReviews")
  counselingSlots     CounselingSlot[]        @relation("StaffSlots")
  counselingBookings  CounselingBooking[]     @relation("AlumniBookings")
  transcriptRequests  TranscriptRequest[]
  achievements        Achievement[]
  congratsGiven       AchievementCongrats[]   @relation("CongratsGiven")
  candidateNotes      CandidateNote[]         @relation("ApplicationNotes")
  pooledCandidates    TalentPoolEntry[]       @relation("PooledCandidates")
  talentPoolOwners    TalentPoolEntry[]       @relation("TalentPoolOwners")
  auditLogs           AuditLog[]              @relation("AuditActor")
  loginEvents         LoginEvent[]
  cvMatchRuns         CvMatchRun[]
}

model Opportunity {
  id                    String          @id @default(cuid())
  title                 String
  description           String
  company               String
  location              String
  locationType          LocationType    @default(ONSITE)
  type                  OpportunityType
  salaryMin             Int?
  salaryMax             Int?
  currency              String          @default("GHS")
  deadline              DateTime?
  requiredSkills        String[]        @default([])
  preferredSkills       String[]        @default([])
  industry              String?
  experienceLevel       String?
  applicationUrl        String?
  postedById            String?
  postedBy              User?           @relation("PostedOpportunities", fields: [postedById], references: [id], onDelete: SetNull)
  isApproved            Boolean         @default(true)
  isActive              Boolean         @default(true)
  isFeatured            Boolean         @default(false)
  customQuestions       Json?
  anonymousApplications Boolean         @default(false)

  source            OpportunitySource @default(USER)
  status            OpportunityStatus @default(PUBLISHED)
  sourceUrl         String?
  sourceName        String?
  confidence        Float?
  verifierReason    String?
  ingestedAt        DateTime?
  category          Json?
  rawPayload        Json?
  additionalSources String[]          @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications Application[]
  bookmarks    Bookmark[]

  @@index([type, locationType, isActive])
  @@index([deadline])
  @@index([source, status])
  @@index([status, ingestedAt])
}

model Application {
  id                      String            @id @default(cuid())
  userId                  String
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId           String
  opportunity             Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  cvUrl                   String?
  coverLetter             String?
  status                  ApplicationStatus @default(APPLIED)
  // ATS extension fields (added in Phase 6, all nullable / defaulted for
  // backward compatibility with the existing apply flow):
  customAnswers           Json?
  recruiterScore          Float?
  recruiterScoreBreakdown Json?
  // v3: AI-driven scoring snapshot computed once at apply-time so
  // recruiter views are token-free. Falls back to the deterministic
  // recruiterScore when AI is rate-limited or off.
  aiScore                 Int?
  aiBreakdown             Json?
  aiReasoning             String?
  aiStrengths             String[]          @default([])
  aiConcerns              String[]          @default([])
  appliedAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  notes CandidateNote[]

  @@unique([userId, opportunityId])
  @@index([opportunityId, status])
}

// Recruiter-side notes on applications, ordered chronologically.
model CandidateNote {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  authorId      String
  author        User        @relation("ApplicationNotes", fields: [authorId], references: [id], onDelete: Cascade)
  body          String
  createdAt     DateTime    @default(now())

  @@index([applicationId, createdAt(sort: Desc)])
}

// Talent pool: candidates an employer has saved for future roles.
model TalentPoolEntry {
  id          String   @id @default(cuid())
  candidateId String
  candidate   User     @relation("PooledCandidates", fields: [candidateId], references: [id], onDelete: Cascade)
  ownerId     String
  owner       User     @relation("TalentPoolOwners", fields: [ownerId], references: [id], onDelete: Cascade)
  notes       String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())

  @@unique([candidateId, ownerId])
  @@index([ownerId, createdAt(sort: Desc)])
}

model Bookmark {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, opportunityId])
}

model Scholarship {
  id             String           @id @default(cuid())
  title          String
  provider       String
  description    String
  eligibility    String
  deadline       DateTime?
  awardAmount    String?
  applicationUrl String
  level          ScholarshipLevel
  fieldOfStudy   String?
  location       String?
  tags           String[]         @default([])
  submittedById  String?
  submittedBy    User?            @relation("PostedScholarships", fields: [submittedById], references: [id], onDelete: SetNull)
  isApproved     Boolean          @default(false)
  isFeatured     Boolean          @default(false)

  source            ScholarshipSource @default(USER)
  status            ScholarshipStatus @default(PUBLISHED)
  sourceUrl         String?
  sourceName        String?
  confidence        Float?
  verifierReason    String?
  ingestedAt        DateTime?
  category          Json?
  rawPayload        Json?
  additionalSources String[]          @default([])

  createdAt DateTime @default(now())

  @@index([level, isApproved])
  @@index([deadline])
  @@index([source, status])
  @@index([status, ingestedAt])
}

model MentorProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertise         String[] @default([])
  availability      String?
  bio               String
  currentRole       String
  company           String
  yearsExperience   Int
  mentoringTopics   String[] @default([])
  mentoringStyles   String[] @default([])
  isActive          Boolean  @default(true)
  averageRating     Float    @default(0)
  sessionsCompleted Int      @default(0)
  createdAt         DateTime @default(now())
}

model MentorshipMatch {
  id        String      @id @default(cuid())
  mentorId  String
  mentor    User        @relation("Mentor", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId  String
  mentee    User        @relation("Mentee", fields: [menteeId], references: [id], onDelete: Cascade)
  status    MatchStatus @default(PENDING)
  goals     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  sessions Session[]

  @@unique([mentorId, menteeId])
}

model Session {
  id             String          @id @default(cuid())
  matchId        String
  match          MentorshipMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  duration       Int             @default(30)
  status         SessionStatus   @default(SCHEDULED)
  mentorRating   Int?
  menteeRating   Int?
  mentorFeedback String?
  menteeFeedback String?
  meetingUrl     String?
  // Mock-interview metadata when this session was booked via the Career
  // Tools mock-interview scheduler. Keys: type (BEHAVIORAL|TECHNICAL|
  // PANEL|CASE), focusArea, seniorityTarget, language, rubric.
  mockMeta       Json?
}

model Event {
  id           String   @id @default(cuid())
  title        String
  description  String
  date         DateTime
  duration     Int      @default(60)
  location     String
  isOnline     Boolean  @default(false)
  capacity     Int      @default(100)
  hostId       String
  host         User     @relation("HostedEvents", fields: [hostId], references: [id], onDelete: Cascade)
  type         String
  recordingUrl String?
  slidesUrl    String?
  createdAt    DateTime @default(now())

  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model CV {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  template  String   @default("modern")
  data      Json
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InterviewExperience {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String
  role      String
  industry  String
  questions String[] @default([])
  tips      String
  rating    Int      @default(3)
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model CareerRoadmap {
  id        String   @id @default(cuid())
  programme String   @unique
  title     String
  steps     Json
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
}

// Cover letters generated via the Career Tools cover-letter builder.
// Each user can have many drafts; `data` holds the structured form fields
// + filled-in body so the editor is fully reconstructable.
model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  template  String   @default("classic")
  data      Json
  jobLinkId String? // Optional link to an Opportunity this letter targets
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
}

// Public portfolio published by an alumnus at /p/<slug>. Each user can
// have multiple portfolios; `slug` is global-unique so URLs stay short.
model Portfolio {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug         String   @unique
  title        String
  tagline      String?
  bio          String?
  theme        String   @default("clean")
  contactEmail String?
  links        Json? // [{ label, url }]
  isPublished  Boolean  @default(false)
  passwordHash String? // optional gating
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects PortfolioProject[]

  @@index([userId])
}

model PortfolioProject {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  position    Int       @default(0)
  title       String
  summary     String
  role        String?
  coverUrl    String?
  techStack   String[]  @default([])
  externalUrl String?
  caseStudyMd String?

  @@index([portfolioId, position])
}

// Document Vault — each row is one stored file owned by a user. Files
// live in Vercel Blob (or local disk in dev); the row holds metadata
// + access control. Per-document share links are tracked in a separate
// table so we can audit who viewed what.
enum VaultCategory {
  TRANSCRIPT
  CERTIFICATE
  REFERENCE
  IDENTIFICATION
  CV
  COVER_LETTER
  OTHER
}

model VaultDocument {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimetype     String
  size         Int
  url          String
  category     VaultCategory @default(OTHER)
  notes        String?
  createdAt    DateTime      @default(now())

  shares VaultShareLink[]

  @@index([userId, createdAt(sort: Desc)])
}

model VaultShareLink {
  id           String        @id @default(cuid())
  documentId   String
  document     VaultDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  token        String        @unique
  passwordHash String?
  expiresAt    DateTime?
  maxViews     Int?
  viewCount    Int           @default(0)
  isRevoked    Boolean       @default(false)
  createdAt    DateTime      @default(now())

  accessLog VaultAccessLog[]

  @@index([documentId])
}

model VaultAccessLog {
  id        String         @id @default(cuid())
  shareId   String
  share     VaultShareLink @relation(fields: [shareId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  createdAt DateTime       @default(now())

  @@index([shareId, createdAt(sort: Desc)])
}

// ===== Phase 2: Skills & Growth =====

// Curated skill taxonomy. Hand-seeded for v1 with the most common
// engineering / energy / business / data skills relevant to UENR
// programmes. Synonyms power fuzzy match in the role-targeting helper
// and (later) the ATS resume parser.
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  synonyms  String[] @default([])
  createdAt DateTime @default(now())

  @@index([category])
}

// Target roles users can self-assess against. Each lists the skills
// the role expects so we can compute a readiness % from the user's
// 1-5 ratings.
model RoleProfile {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  category        String
  requiredSkills  String[] @default([])
  preferredSkills String[] @default([])
  createdAt       DateTime @default(now())

  @@index([category])
}

// One row per assessment a user completes. Stores the user's 1-5
// ratings as JSON keyed by skill name and the computed readiness %.
model SkillAssessment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleSlug    String
  ratings     Json
  readiness   Float    @default(0)
  completedAt DateTime @default(now())

  @@index([userId, completedAt(sort: Desc)])
}

enum LearningType {
  COURSE
  VIDEO
  BOOK
  ARTICLE
  PODCAST
}

enum LearningLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LearningCost {
  FREE
  PAID
  FREEMIUM
}

// Curated + user-submitted learning resources. `isApproved=false` for
// user submissions until an admin approves; curated seed defaults true.
model LearningResource {
  id            String        @id @default(cuid())
  title         String
  provider      String
  url           String
  type          LearningType
  level         LearningLevel
  cost          LearningCost
  language      String        @default("English")
  durationMin   Int?
  skills        String[]      @default([])
  description   String?
  submittedById String?
  submittedBy   User?         @relation("SubmittedResources", fields: [submittedById], references: [id], onDelete: SetNull)
  isApproved    Boolean       @default(true)
  createdAt     DateTime      @default(now())

  @@index([type, level, isApproved])
  @@index([cost, isApproved])
}

// Curated learning paths — ordered sequences of resource ids with
// optional notes on each step.
model LearningPath {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  steps       Json
  createdAt   DateTime @default(now())
}

// Per-user learning progress on individual resources.
model LearningProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId  String
  status      String    @default("IN_PROGRESS")
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, resourceId])
}

// User-tracked certifications with issue + expiry dates and an
// optional VaultDocument back-reference for the cert PDF.
model Certification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  issuer        String
  issueDate     DateTime
  expiryDate    DateTime?
  credentialUrl String?
  vaultDocId    String?
  publicSlug    String?   @unique
  createdAt     DateTime  @default(now())

  @@index([userId, expiryDate])
}

// Career path nodes seeded with UENR-relevant roles. Edges to typical
// next roles are stored as a string array of node slugs to keep the
// model simple — bidirectional traversal happens client-side.
model CareerPathNode {
  id             String   @id @default(cuid())
  slug           String   @unique
  role           String
  level          String
  industry       String
  salaryGhsMin   Int?
  salaryGhsMax   Int?
  yearsTypical   Int      @default(2)
  description    String?
  requiredSkills String[] @default([])
  nextNodeSlugs  String[] @default([])
  createdAt      DateTime @default(now())

  @@index([industry, level])
}

// ===== Phase 3: Interview Prep =====

enum InterviewCategory {
  BEHAVIORAL
  TECHNICAL
  DOMAIN
  CASE
  SITUATIONAL
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
}

// Question bank — curated + community-submitted prompts. `roleSlug` is
// optional and references RoleProfile.slug when the question is bound
// to a particular target role.
model InterviewQuestion {
  id            String              @id @default(cuid())
  prompt        String
  guidance      String?
  sampleAnswer  String?
  category      InterviewCategory
  difficulty    InterviewDifficulty @default(MEDIUM)
  roleSlug      String?
  industry      String?
  tags          String[]            @default([])
  upvotes       Int                 @default(0)
  flagCount     Int                 @default(0)
  isApproved    Boolean             @default(true)
  submittedById String?
  createdAt     DateTime            @default(now())

  votes InterviewQuestionVote[]

  @@index([category, difficulty, isApproved])
  @@index([roleSlug])
}

model InterviewQuestionVote {
  id         String            @id @default(cuid())
  questionId String
  question   InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([questionId, userId])
}

// Aptitude practice. Multiple-choice with single correct answer; the
// `attempt` model groups answers from one practice or mock-test run.
enum AptitudeCategory {
  GMAT_VERBAL
  GMAT_QUANT
  GRE_VERBAL
  GRE_QUANT
  GHANA_CIVIL_SERVICE
  CONSULTING_CASE
  NUMERICAL
  LOGICAL
}

model AptitudeQuestion {
  id               String           @id @default(cuid())
  category         AptitudeCategory
  prompt           String
  options          String[]
  correctIndex     Int
  explanation      String
  difficulty       Int              @default(2)
  estimatedSeconds Int              @default(60)
  createdAt        DateTime         @default(now())

  @@index([category, difficulty])
}

model AptitudeAttempt {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     AptitudeCategory
  isMock       Boolean          @default(false)
  startedAt    DateTime         @default(now())
  completedAt  DateTime?
  totalSeconds Int?
  score        Int?

  answers AptitudeAttemptAnswer[]

  @@index([userId, completedAt(sort: Desc)])
}

model AptitudeAttemptAnswer {
  id            String          @id @default(cuid())
  attemptId     String
  attempt       AptitudeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  selectedIndex Int?
  isCorrect     Boolean         @default(false)
  timeSpentSec  Int             @default(0)

  @@index([attemptId])
}

// Salary benchmarks — one row per (role × seniority × city × currency).
// All amounts are MONTHLY in the row's currency.
model SalaryBenchmark {
  id         String   @id @default(cuid())
  role       String
  seniority  String
  city       String
  country    String
  currency   String
  minMonthly Int
  maxMonthly Int
  source     String?
  notes      String?
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([role, seniority])
  @@index([country, city])
}

// Cost-of-living for the negotiation calculator. One row per city.
model CityCostOfLiving {
  id               String   @id @default(cuid())
  city             String   @unique
  country          String
  currency         String
  rentMonthly      Int
  groceriesMonthly Int
  transportMonthly Int
  utilitiesMonthly Int
  totalMonthly     Int
  notes            String?
  updatedAt        DateTime @updatedAt
}

// ===== Phase 4: Ventures =====

// Downloadable pitch-deck templates for the Startup Resources hub.
// File lives in Vercel Blob; we count downloads for popularity sorting.
model StartupDeckTemplate {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  stage         String
  fileUrl       String
  thumbnailUrl  String?
  downloadCount Int      @default(0)
  createdAt     DateTime @default(now())
}

// Curated incubator / accelerator / hub directory. Ghana-focused.
model Incubator {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  url         String
  location    String
  focus       String[] @default([])
  programType String
  applyUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([programType, isActive])
}

// Curated grants directory with next deadlines.
model Grant {
  id             String    @id @default(cuid())
  slug           String    @unique
  name           String
  provider       String
  description    String
  applicationUrl String
  nextDeadline   DateTime?
  amount         String?
  fitCriteria    String[]  @default([])
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())

  @@index([nextDeadline])
}

// ----- Freelance project board -----

enum GigStatus {
  OPEN
  AWARDED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum GigCategory {
  DESIGN
  DEV
  WRITING
  RESEARCH
  TRANSLATION
  CONSULTING
  OTHER
}

model FreelanceGig {
  id           String      @id @default(cuid())
  posterId     String
  poster       User        @relation("PostedGigs", fields: [posterId], references: [id], onDelete: Cascade)
  title        String
  description  String
  category     GigCategory
  budgetMin    Int
  budgetMax    Int
  currency     String      @default("GHS")
  deadlineAt   DateTime?
  skills       String[]    @default([])
  status       GigStatus   @default(OPEN)
  awardedBidId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  bids FreelanceBid[]

  @@index([status, createdAt(sort: Desc)])
  @@index([category, status])
}

model FreelanceBid {
  id            String       @id @default(cuid())
  gigId         String
  gig           FreelanceGig @relation(fields: [gigId], references: [id], onDelete: Cascade)
  bidderId      String
  bidder        User         @relation("Bids", fields: [bidderId], references: [id], onDelete: Cascade)
  coverNote     String
  priceAmount   Int
  currency      String       @default("GHS")
  deliveryDays  Int
  isShortlisted Boolean      @default(false)
  isAwarded     Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@unique([gigId, bidderId])
  @@index([gigId])
}

model FreelanceReview {
  id         String   @id @default(cuid())
  gigId      String
  reviewerId String
  reviewer   User     @relation("GivenReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  revieweeId String
  reviewee   User     @relation("ReceivedReviews", fields: [revieweeId], references: [id], onDelete: Cascade)
  role       String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([gigId, reviewerId, revieweeId])
}

// ----- Ghana Business Registration walkthrough -----

model BizRegStep {
  id                String   @id @default(cuid())
  slug              String   @unique
  authority         String
  title             String
  description       String
  estimatedTimeDays Int?
  estimatedCostGhs  Int?
  pitfalls          String?
  officialUrl       String?
  formDownloads     Json?
  position          Int      @default(0)
  category          String
  createdAt         DateTime @default(now())

  @@index([category, position])
}

// ===== Phase 5: Support =====

// Career counseling: staff publish bookable slots; alumni book.
enum CounselingMode {
  IN_PERSON
  VIDEO
  PHONE
}

enum CounselingBookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  WAITLIST
}

model CounselingSlot {
  id        String         @id @default(cuid())
  staffId   String
  staff     User           @relation("StaffSlots", fields: [staffId], references: [id], onDelete: Cascade)
  startsAt  DateTime
  endsAt    DateTime
  mode      CounselingMode @default(VIDEO)
  capacity  Int            @default(1)
  isActive  Boolean        @default(true)
  notes     String?
  createdAt DateTime       @default(now())

  bookings CounselingBooking[]

  @@index([staffId, startsAt])
  @@index([startsAt, isActive])
}

model CounselingBooking {
  id                  String                  @id @default(cuid())
  slotId              String
  slot                CounselingSlot          @relation(fields: [slotId], references: [id], onDelete: Cascade)
  alumniId            String
  alumnus             User                    @relation("AlumniBookings", fields: [alumniId], references: [id], onDelete: Cascade)
  topic               String
  preferredMode       CounselingMode
  status              CounselingBookingStatus @default(PENDING)
  staffNotes          String?
  satisfactionRating  Int?
  satisfactionComment String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  @@index([alumniId, createdAt(sort: Desc)])
  @@index([slotId, status])
}

// Transcripts & verification.
enum TranscriptType {
  TRANSCRIPT
  LETTER_OF_ATTENDANCE
  DEGREE_VERIFICATION
}

enum TranscriptDeliveryMethod {
  PICKUP
  POSTAL_LOCAL
  POSTAL_INTERNATIONAL
  ELECTRONIC
}

enum TranscriptStatus {
  SUBMITTED
  UNDER_REVIEW
  PROCESSING
  READY
  DISPATCHED
  DELIVERED
  CANCELLED
}

model TranscriptRequest {
  id                String                   @id @default(cuid())
  userId            String
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              TranscriptType
  copies            Int                      @default(1)
  deliveryMethod    TranscriptDeliveryMethod
  recipientName     String?
  recipientAddress  String?
  recipientEmail    String?
  feeAmountGhs      Int
  paymentRef        String?
  paymentStatus     String                   @default("UNPAID")
  status            TranscriptStatus         @default(SUBMITTED)
  publicVerifyToken String?                  @unique
  notes             String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
}

// Achievements wall — moderated, with congrats threads.
enum AchievementType {
  PROMOTION
  PUBLICATION
  AWARD
  VENTURE_LAUNCH
  COMMUNITY_IMPACT
  MEDIA_FEATURE
  OTHER
}

model Achievement {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          AchievementType
  title         String
  description   String
  date          DateTime
  link          String?
  imageUrl      String?
  isApproved    Boolean         @default(false)
  isFeatured    Boolean         @default(false)
  congratsCount Int             @default(0)
  createdAt     DateTime        @default(now())

  congrats AchievementCongrats[]

  @@index([isApproved, date(sort: Desc)])
  @@index([type, isApproved])
}

model AchievementCongrats {
  id            String      @id @default(cuid())
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation("CongratsGiven", fields: [userId], references: [id], onDelete: Cascade)
  message       String?
  createdAt     DateTime    @default(now())

  @@unique([achievementId, userId])
}

// ===== Phase 7 / Superuser admin layer =====

// Every write a superuser makes through /admin/* writes one of these
// BEFORE the write lands, capturing a structured diff for incident
// response and compliance.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([targetType, targetId])
}

// Login history per user — populated from /auth/login (success + fail).
// Drives the "force logout everywhere" and "view login history" admin
// features.
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Capped, best-effort error log populated by the errorHandler. Drives
// the "last 50 server errors" pane on the system-health admin view.
model ErrorLog {
  id        String   @id @default(cuid())
  message   String
  stack     String?
  path      String?
  method    String?
  status    Int?
  userId    String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

// One row per CV-vs-JD analysis the user runs in the CV Match tool.
// Persisted snapshot of inputs + scoring outputs so a returning user
// can compare runs over time without re-uploading.
model CvMatchRun {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvSource        String
  cvId            String?
  cvText          String?
  jdSource        String
  opportunityId   String?
  jdText          String
  jobTitle        String?
  cvSkills        String[] @default([])
  jdRequired      String[] @default([])
  jdPreferred     String[] @default([])
  jdYearsRequired Int?
  score           Int      @default(0)
  breakdown       Json
  refinements     Json
  missingSkills   String[] @default([])
  // v2: AI augmentation fields. Nullable so existing v1 rows stay valid.
  aiSummary       String?
  aiBullets       Json?
  aiCostTokens    Int?
  // v3: AI is the primary engine. Snapshots so cached views render
  // without re-spending tokens.
  aiScore         Int?
  aiBreakdown     Json? // { hardSkills, softSignals, experience, education, cultureFit, growthSignal } — each 0..1
  aiReasoning     String?
  aiSoftSignals   String[] @default([])
  aiIndustry      String?
  aiSeniority     String?
  aiRefinements   Json? // [{ kind, severity, message, reasoning, skill? }]
  createdAt       DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Activity feed for the Career Tools hub. Each row is one interaction
// (opening a tool, saving a draft, exporting a file, etc.) and powers
// the hub's "Recently used" row.
model CareerToolsActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Admin-editable site content stored as JSON blobs keyed by section.
// Currently: "landing" holds the hero/alumni/story/cta config edited via
// /admin/landing in the UI.
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}

model IngestJob {
  id             String   @id @default(cuid())
  runId          String
  source         String
  status         String
  attempts       Int      @default(0)
  itemsFound     Int?
  itemsPublished Int?
  itemsQueued    Int?
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([runId, source])
  @@index([status, createdAt])
}

model IngestRun {
  id               String    @id @default(cuid())
  startedAt        DateTime  @default(now())
  endedAt          DateTime?
  sourcesAttempted Int       @default(0)
  sourcesOk        Int       @default(0)
  sourcesFailed    Int       @default(0)
  itemsPublished   Int       @default(0)
  itemsQueued      Int       @default(0)
  itemsRejected    Int       @default(0)
  triggeredBy      String

  @@index([startedAt])
}
