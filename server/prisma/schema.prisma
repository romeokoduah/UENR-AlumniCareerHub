// Postgres schema. Used with Neon in production; run against any Postgres
// (including Neon's free branching for local dev).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  // native = local dev OS; rhel-openssl-3.0.x = Vercel serverless Node 20
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

enum Role {
  STUDENT
  ALUMNI
  EMPLOYER
  ADMIN
}

enum OpportunityType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  NATIONAL_SERVICE
  VOLUNTEER
  CONTRACT
}

enum LocationType {
  REMOTE
  ONSITE
  HYBRID
}

enum ApplicationStatus {
  APPLIED
  UNDER_REVIEW
  INTERVIEW
  OFFER
  REJECTED
  WITHDRAWN
}

enum ScholarshipLevel {
  UNDERGRAD
  MASTERS
  PHD
  POSTDOC
  OTHER
}

enum MatchStatus {
  PENDING
  ACCEPTED
  DECLINED
  COMPLETED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationType {
  OPPORTUNITY_MATCH
  MENTORSHIP_REQUEST
  SESSION_REMINDER
  APPLICATION_UPDATE
  EVENT_REMINDER
  ANNOUNCEMENT
  MESSAGE
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  role             Role     @default(STUDENT)
  firstName        String
  lastName         String
  avatar           String?
  bio              String?
  programme        String?
  graduationYear   Int?
  studentId        String?
  skills           String[] @default([])
  linkedinUrl      String?
  phone            String?
  location         String?
  currentRole      String?
  currentCompany   String?
  isVerified       Boolean  @default(false)
  isApproved       Boolean  @default(false)
  profileComplete  Boolean  @default(false)
  visibility       String   @default("members")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  opportunitiesPosted Opportunity[]       @relation("PostedOpportunities")
  applications        Application[]
  bookmarks           Bookmark[]
  scholarshipsPosted  Scholarship[]       @relation("PostedScholarships")
  mentorProfile       MentorProfile?
  mentorMatches       MentorshipMatch[]   @relation("Mentor")
  menteeMatches       MentorshipMatch[]   @relation("Mentee")
  eventsHosted        Event[]             @relation("HostedEvents")
  eventRegistrations  EventRegistration[]
  notifications       Notification[]
  cvs                 CV[]
  interviewPosts      InterviewExperience[]
  chatMessages        ChatMessage[]
  messagesSent        Message[]           @relation("MessagesSent")
  messagesReceived    Message[]           @relation("MessagesReceived")
  careerActivity      CareerToolsActivity[]
  coverLetters        CoverLetter[]
  portfolios          Portfolio[]
  vaultDocuments      VaultDocument[]
  skillAssessments    SkillAssessment[]
  learningProgress    LearningProgress[]
  certifications      Certification[]
  resourcesSubmitted  LearningResource[]  @relation("SubmittedResources")
  questionVotes       InterviewQuestionVote[]
  aptitudeAttempts    AptitudeAttempt[]
}

model Opportunity {
  id              String          @id @default(cuid())
  title           String
  description     String
  company         String
  location        String
  locationType    LocationType    @default(ONSITE)
  type            OpportunityType
  salaryMin       Int?
  salaryMax       Int?
  currency        String          @default("GHS")
  deadline        DateTime
  requiredSkills  String[]        @default([])
  industry        String?
  experienceLevel String?
  applicationUrl  String?
  postedById      String
  postedBy        User            @relation("PostedOpportunities", fields: [postedById], references: [id], onDelete: Cascade)
  isApproved      Boolean         @default(true)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  applications Application[]
  bookmarks    Bookmark[]

  @@index([type, locationType, isActive])
  @@index([deadline])
}

model Application {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  cvUrl         String?
  coverLetter   String?
  status        ApplicationStatus @default(APPLIED)
  appliedAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([userId, opportunityId])
}

model Bookmark {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@unique([userId, opportunityId])
}

model Scholarship {
  id              String           @id @default(cuid())
  title           String
  provider        String
  description     String
  eligibility     String
  deadline        DateTime
  awardAmount     String?
  applicationUrl  String
  level           ScholarshipLevel
  fieldOfStudy    String?
  location        String?
  tags            String[]         @default([])
  submittedById   String
  submittedBy     User             @relation("PostedScholarships", fields: [submittedById], references: [id], onDelete: Cascade)
  isApproved      Boolean          @default(false)
  createdAt       DateTime         @default(now())

  @@index([level, isApproved])
  @@index([deadline])
}

model MentorProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertise         String[] @default([])
  availability      String?
  bio               String
  currentRole       String
  company           String
  yearsExperience   Int
  mentoringTopics   String[] @default([])
  mentoringStyles   String[] @default([])
  isActive          Boolean  @default(true)
  averageRating     Float    @default(0)
  sessionsCompleted Int      @default(0)
  createdAt         DateTime @default(now())
}

model MentorshipMatch {
  id         String      @id @default(cuid())
  mentorId   String
  mentor     User        @relation("Mentor", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId   String
  mentee     User        @relation("Mentee", fields: [menteeId], references: [id], onDelete: Cascade)
  status     MatchStatus @default(PENDING)
  goals      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  sessions Session[]

  @@unique([mentorId, menteeId])
}

model Session {
  id             String          @id @default(cuid())
  matchId        String
  match          MentorshipMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  duration       Int             @default(30)
  status         SessionStatus   @default(SCHEDULED)
  mentorRating   Int?
  menteeRating   Int?
  mentorFeedback String?
  menteeFeedback String?
  meetingUrl     String?
  // Mock-interview metadata when this session was booked via the Career
  // Tools mock-interview scheduler. Keys: type (BEHAVIORAL|TECHNICAL|
  // PANEL|CASE), focusArea, seniorityTarget, language, rubric.
  mockMeta       Json?
}

model Event {
  id           String   @id @default(cuid())
  title        String
  description  String
  date         DateTime
  duration     Int      @default(60)
  location     String
  isOnline     Boolean  @default(false)
  capacity     Int      @default(100)
  hostId       String
  host         User     @relation("HostedEvents", fields: [hostId], references: [id], onDelete: Cascade)
  type         String
  recordingUrl String?
  slidesUrl    String?
  createdAt    DateTime @default(now())

  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

model CV {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  template  String   @default("modern")
  data      Json
  pdfUrl    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InterviewExperience {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   String
  role      String
  industry  String
  questions String[] @default([])
  tips      String
  rating    Int      @default(3)
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([sessionId])
}

model CareerRoadmap {
  id        String   @id @default(cuid())
  programme String   @unique
  title     String
  steps     Json
  createdAt DateTime @default(now())
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
}

// Cover letters generated via the Career Tools cover-letter builder.
// Each user can have many drafts; `data` holds the structured form fields
// + filled-in body so the editor is fully reconstructable.
model CoverLetter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  template  String   @default("classic")
  data      Json
  jobLinkId String?  // Optional link to an Opportunity this letter targets
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
}

// Public portfolio published by an alumnus at /p/<slug>. Each user can
// have multiple portfolios; `slug` is global-unique so URLs stay short.
model Portfolio {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug         String   @unique
  title        String
  tagline      String?
  bio          String?
  theme        String   @default("clean")
  contactEmail String?
  links        Json?    // [{ label, url }]
  isPublished  Boolean  @default(false)
  passwordHash String?  // optional gating
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects PortfolioProject[]

  @@index([userId])
}

model PortfolioProject {
  id           String    @id @default(cuid())
  portfolioId  String
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  position     Int       @default(0)
  title        String
  summary      String
  role         String?
  coverUrl     String?
  techStack    String[]  @default([])
  externalUrl  String?
  caseStudyMd  String?

  @@index([portfolioId, position])
}

// Document Vault — each row is one stored file owned by a user. Files
// live in Vercel Blob (or local disk in dev); the row holds metadata
// + access control. Per-document share links are tracked in a separate
// table so we can audit who viewed what.
enum VaultCategory {
  TRANSCRIPT
  CERTIFICATE
  REFERENCE
  IDENTIFICATION
  CV
  COVER_LETTER
  OTHER
}

model VaultDocument {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename    String
  originalName String
  mimetype    String
  size        Int
  url         String
  category    VaultCategory @default(OTHER)
  notes       String?
  createdAt   DateTime      @default(now())

  shares VaultShareLink[]

  @@index([userId, createdAt(sort: Desc)])
}

model VaultShareLink {
  id            String        @id @default(cuid())
  documentId    String
  document      VaultDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  token         String        @unique
  passwordHash  String?
  expiresAt     DateTime?
  maxViews      Int?
  viewCount     Int           @default(0)
  isRevoked     Boolean       @default(false)
  createdAt     DateTime      @default(now())

  accessLog VaultAccessLog[]

  @@index([documentId])
}

model VaultAccessLog {
  id        String         @id @default(cuid())
  shareId   String
  share     VaultShareLink @relation(fields: [shareId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  createdAt DateTime       @default(now())

  @@index([shareId, createdAt(sort: Desc)])
}

// ===== Phase 2: Skills & Growth =====

// Curated skill taxonomy. Hand-seeded for v1 with the most common
// engineering / energy / business / data skills relevant to UENR
// programmes. Synonyms power fuzzy match in the role-targeting helper
// and (later) the ATS resume parser.
model Skill {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  synonyms  String[] @default([])
  createdAt DateTime @default(now())

  @@index([category])
}

// Target roles users can self-assess against. Each lists the skills
// the role expects so we can compute a readiness % from the user's
// 1-5 ratings.
model RoleProfile {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?
  category        String
  requiredSkills  String[] @default([])
  preferredSkills String[] @default([])
  createdAt       DateTime @default(now())

  @@index([category])
}

// One row per assessment a user completes. Stores the user's 1-5
// ratings as JSON keyed by skill name and the computed readiness %.
model SkillAssessment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleSlug    String
  ratings     Json
  readiness   Float    @default(0)
  completedAt DateTime @default(now())

  @@index([userId, completedAt(sort: Desc)])
}

enum LearningType {
  COURSE
  VIDEO
  BOOK
  ARTICLE
  PODCAST
}

enum LearningLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LearningCost {
  FREE
  PAID
  FREEMIUM
}

// Curated + user-submitted learning resources. `isApproved=false` for
// user submissions until an admin approves; curated seed defaults true.
model LearningResource {
  id            String        @id @default(cuid())
  title         String
  provider      String
  url           String
  type          LearningType
  level         LearningLevel
  cost          LearningCost
  language      String        @default("English")
  durationMin   Int?
  skills        String[]      @default([])
  description   String?
  submittedById String?
  submittedBy   User?         @relation("SubmittedResources", fields: [submittedById], references: [id], onDelete: SetNull)
  isApproved    Boolean       @default(true)
  createdAt     DateTime      @default(now())

  @@index([type, level, isApproved])
  @@index([cost, isApproved])
}

// Curated learning paths — ordered sequences of resource ids with
// optional notes on each step.
model LearningPath {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  steps       Json
  createdAt   DateTime @default(now())
}

// Per-user learning progress on individual resources.
model LearningProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceId  String
  status      String    @default("IN_PROGRESS")
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([userId, resourceId])
}

// User-tracked certifications with issue + expiry dates and an
// optional VaultDocument back-reference for the cert PDF.
model Certification {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  issuer        String
  issueDate     DateTime
  expiryDate    DateTime?
  credentialUrl String?
  vaultDocId    String?
  publicSlug    String?   @unique
  createdAt     DateTime  @default(now())

  @@index([userId, expiryDate])
}

// Career path nodes seeded with UENR-relevant roles. Edges to typical
// next roles are stored as a string array of node slugs to keep the
// model simple — bidirectional traversal happens client-side.
model CareerPathNode {
  id             String   @id @default(cuid())
  slug           String   @unique
  role           String
  level          String
  industry       String
  salaryGhsMin   Int?
  salaryGhsMax   Int?
  yearsTypical   Int      @default(2)
  description    String?
  requiredSkills String[] @default([])
  nextNodeSlugs  String[] @default([])
  createdAt      DateTime @default(now())

  @@index([industry, level])
}

// ===== Phase 3: Interview Prep =====

enum InterviewCategory {
  BEHAVIORAL
  TECHNICAL
  DOMAIN
  CASE
  SITUATIONAL
}

enum InterviewDifficulty {
  EASY
  MEDIUM
  HARD
}

// Question bank — curated + community-submitted prompts. `roleSlug` is
// optional and references RoleProfile.slug when the question is bound
// to a particular target role.
model InterviewQuestion {
  id             String              @id @default(cuid())
  prompt         String
  guidance       String?
  sampleAnswer   String?
  category       InterviewCategory
  difficulty     InterviewDifficulty @default(MEDIUM)
  roleSlug       String?
  industry       String?
  tags           String[]            @default([])
  upvotes        Int                 @default(0)
  flagCount      Int                 @default(0)
  isApproved     Boolean             @default(true)
  submittedById  String?
  createdAt      DateTime            @default(now())

  votes InterviewQuestionVote[]

  @@index([category, difficulty, isApproved])
  @@index([roleSlug])
}

model InterviewQuestionVote {
  id         String            @id @default(cuid())
  questionId String
  question   InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime          @default(now())

  @@unique([questionId, userId])
}

// Aptitude practice. Multiple-choice with single correct answer; the
// `attempt` model groups answers from one practice or mock-test run.
enum AptitudeCategory {
  GMAT_VERBAL
  GMAT_QUANT
  GRE_VERBAL
  GRE_QUANT
  GHANA_CIVIL_SERVICE
  CONSULTING_CASE
  NUMERICAL
  LOGICAL
}

model AptitudeQuestion {
  id               String           @id @default(cuid())
  category         AptitudeCategory
  prompt           String
  options          String[]
  correctIndex     Int
  explanation      String
  difficulty       Int              @default(2)
  estimatedSeconds Int              @default(60)
  createdAt        DateTime         @default(now())

  @@index([category, difficulty])
}

model AptitudeAttempt {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     AptitudeCategory
  isMock       Boolean                 @default(false)
  startedAt    DateTime                @default(now())
  completedAt  DateTime?
  totalSeconds Int?
  score        Int?

  answers AptitudeAttemptAnswer[]

  @@index([userId, completedAt(sort: Desc)])
}

model AptitudeAttemptAnswer {
  id            String          @id @default(cuid())
  attemptId     String
  attempt       AptitudeAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  selectedIndex Int?
  isCorrect     Boolean         @default(false)
  timeSpentSec  Int             @default(0)

  @@index([attemptId])
}

// Salary benchmarks — one row per (role × seniority × city × currency).
// All amounts are MONTHLY in the row's currency.
model SalaryBenchmark {
  id          String   @id @default(cuid())
  role        String
  seniority   String
  city        String
  country     String
  currency    String
  minMonthly  Int
  maxMonthly  Int
  source      String?
  notes       String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([role, seniority])
  @@index([country, city])
}

// Cost-of-living for the negotiation calculator. One row per city.
model CityCostOfLiving {
  id               String   @id @default(cuid())
  city             String   @unique
  country          String
  currency         String
  rentMonthly      Int
  groceriesMonthly Int
  transportMonthly Int
  utilitiesMonthly Int
  totalMonthly     Int
  notes            String?
  updatedAt        DateTime @updatedAt
}

// Activity feed for the Career Tools hub. Each row is one interaction
// (opening a tool, saving a draft, exporting a file, etc.) and powers
// the hub's "Recently used" row.
model CareerToolsActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool      String
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Admin-editable site content stored as JSON blobs keyed by section.
// Currently: "landing" holds the hero/alumni/story/cta config edited via
// /admin/landing in the UI.
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  data      Json
  updatedAt DateTime @updatedAt
}
