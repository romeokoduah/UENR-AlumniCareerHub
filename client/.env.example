# Frontend environment variables.
# Copy to client/.env.local for local overrides, or set these in the Vercel
# project's Environment Variables dashboard for production.

# Backend origin (NO trailing slash, NO /api suffix — the client appends /api itself).
# Leave blank for local dev (Vite proxies /api and /uploads to :4000 automatically).
# Example for production:
# VITE_API_URL=https://uenr-career-hub-api.up.railway.app
VITE_API_URL=
