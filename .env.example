# ============================================================
#  Server — local dev
# ============================================================
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ----- Database (Neon Postgres) -----
# Create a free project at https://console.neon.tech then copy your
# *pooled* connection string here (ends with -pooler.neon.tech).
# Also copy the *direct* (non-pooled) string for migrations.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ----- Auth -----
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=7d

# ----- Anthropic (CareerMate chatbot + AI reviews) -----
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ----- Vercel Blob (image uploads for the landing editor) -----
# On Vercel: link a Blob store to your project and this is auto-injected.
# Locally: run `vercel env pull .env.local` or paste the token from
# the Vercel dashboard (Storage → your Blob store → .env.local tab).
# Without it, uploads fall back to server/uploads/ (local dev only — no
# persistent disk on serverless).
BLOB_READ_WRITE_TOKEN=

# ----- Email (Nodemailer, optional) -----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="UENR Career Hub <no-reply@uenr.edu.gh>"

# ----- Google OAuth (optional) -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
